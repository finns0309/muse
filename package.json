{
  "name": "muse",
  "productName": "Muse",
  "version": "0.1.1",
  "private": true,
  "description": "Local NetEase music runtime for fast library routing and accurate echo state.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "release": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "@neteasecloudmusicapienhanced/api": "^4.32.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.finn.muse",
    "publish": {
      "provider": "github",
      "owner": "finns0309",
      "repo": "muse"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "lib/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "dmg": {
      "title": "Muse"
    }
  }
}
